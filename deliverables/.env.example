# PostgreSQL connection used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/second_brain?schema=public"

# Public canonical URL for this Next.js app.
# Local: http://localhost:3000
# Production: https://your-domain.example
NEXTAUTH_URL="http://localhost:3000"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"

# Google Cloud OAuth 2.0 client credentials.
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

